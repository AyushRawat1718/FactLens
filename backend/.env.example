# ----------------------------------
# AI Provider API Keys (all required — Groq is tried first, OpenRouter
# is the automatic fallback if Groq's quota/rate-limit is hit)
# ----------------------------------
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key

# ----------------------------------
# AI Models
# ----------------------------------
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free

# ----------------------------------
# Evidence retrieval (required — used to ground every claim verification)
# ----------------------------------
TAVILY_API_KEY=your_tavily_key

# Number of Tavily search results retrieved per claim
MAX_EVIDENCE_RESULTS=5

# ----------------------------------
# How many claims are sent to the LLM in a single batched request
# ----------------------------------
BATCH_SIZE=5

# ----------------------------------
# Hugging Face claim-classifier model
# ----------------------------------
HF_MODEL_ID=ayushrawat-1718/youtube-fact-checker-roberta

# ----------------------------------
# Server (used when deploying, e.g. Render/Railway set PORT for you)
# ----------------------------------
HOST=0.0.0.0
PORT=8000

# ----------------------------------
# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for local development only — restrict this in production.
# ----------------------------------
CORS_ORIGINS=http://localhost:5173
