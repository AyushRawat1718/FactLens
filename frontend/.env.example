# URL of the FactLens FastAPI backend (no trailing slash)
VITE_API_URL=http://localhost:8000

# Demo video for the landing page — set ONE of these once recorded.
# YouTube (upload as Unlisted, not Private, or it won't embed):
# VITE_DEMO_YOUTUBE_ID=xxxxxxxxxxx
# Self-hosted mp4 (place the file in frontend/public/):
VITE_DEMO_VIDEO_URL=/demo.mp4

# Set to "true" once the backend is stably hosted and reachable at VITE_API_URL.
# When false/unset, the dashboard shows an honest offline notice instead of a dead form.
VITE_LIVE_DEMO=true
